	"scripts": {
		"analyze": "run-s build:web build:analyze",
		"build": "run-s clean build:electron",
		"build:analyze": "source-map-explorer 'dist/web/static/js/*.js'",
		"build:docs": "cd docs/en && mdbook build",
		"build:native": "node scripts/build-native.mjs",
		"build:wasm": "node scripts/build-wasm.mjs",
		"build:web": "tsc && vite build",
		"postbuild:web": "cpy --cwd 'dist/web' './**' '../../electron-build/renderer' && node scripts/archive-web.mjs",
		"build:electron": "npm-run-all --parallel build:web build:native --serial build:electron-main build:electron-bundle",
		"prebuild:electron-main": "rimraf electron-build/main",
		"build:electron-main": "tsc --project tsconfig.electron.json && node scripts/copy-native.mjs",
		"build:electron-bundle": "npm run release:clean && electron-builder --config electron-builder.config.js --linux --mac --windows --publish=never && npm run release:organize",
		"release:clean": "node scripts/clean-release.mjs",
		"release:organize": "node scripts/organize-release.mjs",
		"bench:fixtures": "node benchmarks/generate-fixtures.mjs",
		"bench:fixtures:large": "node benchmarks/generate-fixtures.mjs --large",
		"clean": "rimraf dist electron-build release",
		"check:core-boundaries": "node scripts/check-core-mutation-boundaries.mjs",
		"dist": "run-s clean build:electron",
		"e2e": "playwright test",
		"format": "prettier --write \"*.{js,json,ts,mts,html,md}\" \"src/**/*.{ts,tsx,js,jsx,css,json,md,html}\" \"scripts/**/*.mjs\" \"e2e/**/*.ts\" \"benchmarks/**/*.mjs\" \"public/locales/**/*.{json,md}\" \"docs/reference/**/*.md\"",
		"format:check": "prettier --check \"*.{js,json,ts,mts,html,md}\" \"src/**/*.{ts,tsx,js,jsx,css,json,md,html}\" \"scripts/**/*.mjs\" \"e2e/**/*.ts\" \"benchmarks/**/*.mjs\" \"public/locales/**/*.{json,md}\" \"docs/reference/**/*.md\"",
		"lint": "run-s check:core-boundaries lint:eslint",
		"lint:eslint": "eslint src",
		"perf:unit": "jest src/core/__tests__/graph-projection.parity.test.ts src/core/__tests__/wasm-worker-client.test.ts --runInBand",
		"start": "vite",
		"start:docs": "cd docs/en && mdbook serve",
		"start:electron": "NODE_ENV=development npm-run-all --serial clean --parallel build:web build:native --serial build:electron-main start:electron:boot",
		"start:electron:boot": "electron electron-build/main/src/electron/main-process/index.js",
		"test": "jest --watch",
		"test:coverage": "jest --coverage",
		"version:bump": "node scripts/version-bump.mjs"
	},
	"homepage": "./",
	"main": "electron-build/electron/src/electron/main-process/index.js"
}
